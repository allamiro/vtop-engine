{
  "uid": "vtop-logs",
  "title": "VTOP \u2014 Logs",
  "description": "Raw structured events from every lab component. The engine's metrics now come from its own /metrics endpoint, so logs are where the high-cardinality detail lives: batch_id, object URIs, error text \u2014 the things that must never become metric labels. When a stat panel goes red, the reason is here.",
  "tags": [
    "vtop",
    "logs"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "title": "Engine",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "logs",
      "title": "Errors and warnings",
      "description": "Look here first when a stat panel goes red. The engine emits JSON logs (VTOP_LOG_FORMAT=json), so `| json` exposes `level` and the structured fields as filterable labels.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=\"vtop-engine\"} | json | level=~\"WARN|ERROR\"",
          "legendFormat": "",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    },
    {
      "type": "logs",
      "title": "Committed batches \u2014 commit + object URI",
      "description": "The high-cardinality detail metrics deliberately omit \u2014 batch ids and object URIs. Two correlated events per batch_id: object_uploaded carries the object `uri` (where it landed); source_committed marks the commit that only happens after VERIFIED. The audit trail behind the committed-count stat.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=\"vtop-engine\", event=~\"source_committed|object_uploaded\"} | json",
          "legendFormat": "",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    },
    {
      "type": "row",
      "title": "All components",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "logs",
      "title": "All lab logs",
      "description": "Engine, Kafka, MinIO and the collector together \u2014 useful when the question is which component broke first.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{job=\"docker\"}",
          "legendFormat": "",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ]
}

{
  "uid": "vtop-safety",
  "title": "VTOP \u2014 Safety & invariant",
  "description": "The engine's whole purpose: SOURCE_COMMITTED is forbidden until VERIFIED. This dashboard watches the invariant and its failure modes.",
  "tags": [
    "vtop",
    "safety"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "title": "The invariant",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Verification failures (1h)",
      "description": "An uploaded object did not match its manifest checksum/size. The engine refuses to commit the source, so nothing is lost \u2014 but the batch is stuck and someone must look.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum(increase(vtop_verification_failures_total[1h])) or vector(0)",
          "legendFormat": "failures"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNonNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "type": "stat",
      "title": "Backend-limited verifications (1h)",
      "description": "Verified by SIZE ONLY, not checksum \u2014 the backend could not do better. Committing on this is weaker than the protocol intends. Set upload.require_strong_verification: true in production to refuse it.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum(increase(vtop_verification_backend_limited_total[1h])) or vector(0)",
          "legendFormat": "size-only"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNonNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "type": "stat",
      "title": "Replay required (1h)",
      "description": "Batches returned to the source for re-reading after a failure. Safe by design, but a steady rate means repeated wasted work.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum(increase(vtop_replay_required_total[1h])) or vector(0)",
          "legendFormat": "replays"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNonNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "type": "row",
      "title": "Recovery",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Recovery scans (engine restarts)",
      "description": "Emitted at startup for each incomplete batch found. A spike means the engine restarted with work in flight \u2014 check that those batches then reached source_committed.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service=\"vtop-engine\"} |= \"recovery_scan\" [5m]))",
          "legendFormat": "recovery_scan",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "type": "timeseries",
      "title": "Verified vs committed (committed must never exceed verified)",
      "description": "verification_passed should be immediately followed by source_committed. A persistent gap means batches are verifying but not committing \u2014 the exact state the VERIFIED-but-not-committed recovery path exists for.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum(rate(vtop_verified_total[5m]))",
          "legendFormat": "verified/sec"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum(rate(vtop_commits_total[5m]))",
          "legendFormat": "committed/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {}
    }
  ]
}

{
  "uid": "vtop-overview",
  "title": "VTOP \u2014 Overview",
  "description": "One screen: is telemetry flowing from source to verified object, and is anything failing verification? Engine panels use the engine's own metrics; see the 'VTOP Engine' dashboard for depth.",
  "tags": [
    "vtop",
    "overview"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "title": "Is it working?",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false,
      "panels": [],
      "id": 1
    },
    {
      "type": "stat",
      "title": "Batches committed (5m)",
      "description": "A commit means a batch completed the FULL verified pipeline. Zero while data is flowing means the pipeline is stalled.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum(increase(vtop_commits_total[5m])) or vector(0)",
          "legendFormat": "committed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNonNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "text": {
          "valueSize": 22
        },
        "justifyMode": "center",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "showPercentChange": false,
        "wideLayout": true
      },
      "pluginVersion": "13.1.0",
      "id": 2
    },
    {
      "type": "stat",
      "title": "Verification failures (5m)",
      "description": "ANY non-zero value is an incident: an object did not match its manifest. The engine refuses to commit, so data is safe but stuck.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum(increase(vtop_verification_failures_total[5m])) or vector(0)",
          "legendFormat": "failures"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNonNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "text": {
          "valueSize": 22
        },
        "justifyMode": "center",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "showPercentChange": false,
        "wideLayout": true
      },
      "pluginVersion": "13.1.0",
      "id": 3
    },
    {
      "type": "stat",
      "title": "Replays required (5m)",
      "description": "Batches sent back to be re-read from source. A steady rate means work is being redone.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum(increase(vtop_replay_required_total[5m])) or vector(0)",
          "legendFormat": "replays"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNonNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "text": {
          "valueSize": 22
        },
        "justifyMode": "center",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "showPercentChange": false,
        "wideLayout": true
      },
      "pluginVersion": "13.1.0",
      "id": 4
    },
    {
      "type": "stat",
      "title": "Objects in MinIO",
      "description": "Objects actually landed in object storage \u2014 the destination side of the same story.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum(minio_cluster_usage_object_total)",
          "legendFormat": "objects"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNonNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none",
        "text": {
          "valueSize": 22
        },
        "justifyMode": "center",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "showPercentChange": false,
        "wideLayout": true
      },
      "pluginVersion": "13.1.0",
      "id": 5
    },
    {
      "type": "row",
      "title": "Flow",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "collapsed": false,
      "panels": [],
      "id": 6
    },
    {
      "type": "timeseries",
      "title": "Batches by state (per sec)",
      "description": "The pipeline funnel. verified and source_committed should track each other; where the lines diverge is where batches are stopping.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum by (state) (rate(vtop_batches_total[5m]))",
          "legendFormat": "{{state}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "id": 7
    },
    {
      "type": "timeseries",
      "title": "Kafka consumer lag",
      "description": "Records produced but not yet committed by VTOP. Offsets advance only after VERIFIED, so lag falling to 0 proves the whole verified path is working end to end.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum by (topic) (kafka_consumergroup_lag{consumergroup=\"vtop-engine\"})",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "id": 8
    }
  ]
}

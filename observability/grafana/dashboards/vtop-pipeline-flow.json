{
  "uid": "vtop-pipeline-flow",
  "title": "VTOP \u2014 Pipeline flow (live)",
  "description": "SCADA-style live diagram of the telemetry path, built with Canvas.",
  "tags": [
    "vtop",
    "pipeline",
    "flow"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "title": "Live pipeline",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "canvas",
      "title": "VTOP telemetry pipeline (live)",
      "description": "The telemetry path with a logo at each stage and live numbers on the arrows. Verify-before-commit is the centre: nothing reaches the committed count until it is VERIFIED. Built with the core Canvas panel - the flowchart plugin is AngularJS and does not load on Grafana 13.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 18,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "refId": "A",
          "expr": "sum(rate(kafka_topic_partition_current_offset{topic!~\"__.*\"}[1m])) or vector(0)",
          "instant": true,
          "legendFormat": "msgin"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "refId": "B",
          "expr": "sum(rate(vtop_bytes_in_total[1m])) or vector(0)",
          "instant": true,
          "legendFormat": "bytesin"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "refId": "C",
          "expr": "sum(rate(vtop_bytes_out_total[1m])) or vector(0)",
          "instant": true,
          "legendFormat": "bytesout"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "refId": "D",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(vtop_compression_ratio_bucket[5m]))) and (sum(rate(vtop_compression_ratio_bucket[5m])) > 0) or vector(0)",
          "instant": true,
          "legendFormat": "ratio"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "refId": "E",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(vtop_stage_duration_seconds_bucket[5m]))) and (sum(rate(vtop_stage_duration_seconds_bucket[5m])) > 0) or vector(0)",
          "instant": true,
          "legendFormat": "p95"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "refId": "F",
          "expr": "sum(vtop_commits_total) or vector(0)",
          "instant": true,
          "legendFormat": "commits"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "refId": "G",
          "expr": "sum(increase(vtop_failed_total[1h])) or vector(0)",
          "instant": true,
          "legendFormat": "failed"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "refId": "H",
          "expr": "sum(kafka_consumergroup_lag{consumergroup=\"vtop-engine\"}) or vector(0)",
          "instant": true,
          "legendFormat": "lag"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "refId": "I",
          "expr": "vtop_inflight_batches or vector(0)",
          "instant": true,
          "legendFormat": "inflight"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "refId": "J",
          "expr": "sum(rate(vtop_records_total[1m])) or vector(0)",
          "instant": true,
          "legendFormat": "recsout"
        }
      ],
      "options": {
        "inlineEditing": true,
        "showAdvancedTypes": true,
        "panZoom": false,

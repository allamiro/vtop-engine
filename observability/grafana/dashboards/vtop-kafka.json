{
  "uid": "vtop-kafka",
  "title": "VTOP \u2014 Kafka source",
  "description": "Kafka exposes JMX, not Prometheus; these come from the kafka-exporter sidecar. If every panel is empty, check that target in the Alloy UI (:12345) \u2014 an absent exporter looks identical to zero traffic.",
  "tags": [
    "vtop",
    "kafka"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "title": "Consumer lag (the invariant, seen from Kafka)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Lag by topic",
      "description": "VTOP commits offsets ONLY after VERIFIED, so lag is the backlog of records not yet safely archived. Lag reaching 0 is the end-to-end proof.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum by (topic) (kafka_consumergroup_lag{consumergroup=\"vtop-engine\"})",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "type": "timeseries",
      "title": "Lag by partition",
      "description": "Useful when scaling: engine replicas are bounded by partition count, so more replicas than partitions adds nothing.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum by (topic, partition) (kafka_consumergroup_lag{consumergroup=\"vtop-engine\"})",
          "legendFormat": "{{topic}}-p{{partition}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "type": "row",
      "title": "Topics",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Messages in/sec by topic",
      "description": "Production rate \u2014 the load side of the picture.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum by (topic) (rate(kafka_topic_partition_current_offset[1m]))",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "type": "timeseries",
      "title": "Partitions per topic",
      "description": "The ceiling on useful engine replicas for that topic.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "count by (topic) (kafka_topic_partition_current_offset)",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {}
    }
  ]
}

{
  "uid": "vtop-pipeline",
  "title": "VTOP \u2014 Pipeline performance",
  "description": "Throughput, compression and per-stage latency from the engine's own Prometheus metrics (#46). These were previously reconstructed from batch_metrics log events; they are now native counters and histograms, so there is no log-parsing fragility and the numbers survive log rotation.",
  "tags": [
    "vtop",
    "performance"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "title": "Throughput",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Records/sec",
      "description": "Records leaving the engine into archived objects.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum(rate(vtop_records_total[1m])) or vector(0)",
          "legendFormat": "records/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "type": "timeseries",
      "title": "Bytes in vs out",
      "description": "The gap between the two lines is what compression is saving on the wire.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum(rate(vtop_bytes_in_total[1m])) or vector(0)",
          "legendFormat": "uncompressed in"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum(rate(vtop_bytes_out_total[1m])) or vector(0)",
          "legendFormat": "compressed out (on the wire)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "Bps"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "type": "timeseries",
      "title": "Compression ratio",
      "description": "uncompressed/compressed; higher is better. A sudden drop toward 1.0 suggests the data shape changed or compression is effectively off. Guarded so an idle histogram reads 0, not NaN.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "histogram_quantile(0.5, sum by (le) (rate(vtop_compression_ratio_bucket[5m]))) and (sum(rate(vtop_compression_ratio_bucket[5m])) > 0) or vector(0)",
          "legendFormat": "p50"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(vtop_compression_ratio_bucket[5m]))) and (sum(rate(vtop_compression_ratio_bucket[5m])) > 0) or vector(0)",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "type": "row",
      "title": "Latency by stage",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Per-stage duration (p95)",
      "description": "Which stage owns the time. Upload usually dominates - it is the documented bottleneck, not the state store.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "histogram_quantile(0.95, sum by (le, stage) (rate(vtop_stage_duration_seconds_bucket[5m]))) and (sum by (stage) (rate(vtop_stage_duration_seconds_bucket[5m])) > 0)",
          "legendFormat": "{{stage}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "s"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "type": "timeseries",
      "title": "Total batch latency",
      "description": "Batch start to source-committed. NOTE: batches seal on max_batch_age (60s by default), so an idle lab shows a sawtooth - that is the timer, not slowness.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "histogram_quantile(0.5, sum by (le) (rate(vtop_batch_duration_seconds_bucket[5m]))) and (sum(rate(vtop_batch_duration_seconds_bucket[5m])) > 0)",
          "legendFormat": "p50"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(vtop_batch_duration_seconds_bucket[5m]))) and (sum(rate(vtop_batch_duration_seconds_bucket[5m])) > 0)",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "s"
        },
        "overrides": []
      },
      "options": {}
    }
  ]
}

# =============================================================================
# VTOP Engine — environment template
# =============================================================================
#
#   cp .env.example .env
#   docker compose up -d
#
# Docker Compose reads `.env` automatically. Every value here is already
# hard-coded to a working lab default in docker-compose.yml, so the lab runs
# with NO .env at all — copy this when you want to change something, or as a
# checklist of the full configuration surface before a real deployment.
#
# Each entry is marked:
#   [REQUIRED]  the engine will not start (or will not work) without it
#   [OPTIONAL]  has a default, shown next to it
#   [LAB ONLY]  safe on a laptop, unsafe anywhere reachable
#
# `.env` is gitignored. Do NOT put production secrets in it — real deployments
# should inject secrets via a secret manager or mounted files. See
# docs/SECURITY_MODEL.md.
#
# Values here are ENVIRONMENT. Batching, sources, partitioning and streams are
# YAML, not env — see examples/config.yaml and examples/streams.yaml. The few
# YAML knobs that most affect measured behaviour are noted at the bottom.


# -----------------------------------------------------------------------------
# 1. Object storage credentials
# -----------------------------------------------------------------------------
# Read by the AWS SDK itself, not by VTOP, so the whole standard credential
# chain works: these variables, ~/.aws/credentials, IMDS/IRSA on EC2/EKS, etc.
# On AWS with an instance role or IRSA, leave all three unset.

# [REQUIRED for the lab] MinIO's default root credentials. [LAB ONLY] — these
# are published defaults; never reuse them anywhere reachable.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# [OPTIONAL] default: us-east-1. MinIO ignores it, but the SDK requires *a*
# region to sign requests.
AWS_REGION=us-east-1

# [OPTIONAL] no default. Use a named profile from ~/.aws/credentials instead of
# the keys above. Mutually exclusive with them in practice — pick one.
# AWS_PROFILE=my-profile

# [OPTIONAL] no default. Only for temporary/STS credentials.
# AWS_SESSION_TOKEN=


# -----------------------------------------------------------------------------
# 2. S3 backend behaviour
# -----------------------------------------------------------------------------

# [OPTIONAL] default: unset (real AWS S3). Set to point at an S3-compatible
# service — MinIO here. Unset this to talk to actual AWS.
VTOP_S3_ENDPOINT_URL=http://minio:9000

# [OPTIONAL] default: false. Path-style puts the bucket in the URL path
# (http://host/bucket/key) instead of the hostname
# (http://bucket.host/key). MinIO REQUIRES path-style; AWS S3 does not.
VTOP_S3_FORCE_PATH_STYLE=true

# [OPTIONAL] default: true. [LAB ONLY when false] — the lab's MinIO speaks
# plain HTTP so there is no certificate to verify. MUST be true against
# anything real: false disables TLS certificate validation entirely.
VTOP_S3_VERIFY_TLS=false


# -----------------------------------------------------------------------------
# 3. Engine
# -----------------------------------------------------------------------------

# [OPTIONAL] default: /app/examples/config.yaml (set in docker/Dockerfile).
# Path to config.yaml INSIDE the container. Outside Docker, prefer the
# explicit flag: vtopctl run --config path/to/config.yaml
VTOP_CONFIG=/app/examples/config.yaml

# [OPTIONAL] default: engine.log_level from config.yaml (INFO). Standard
# tracing filter — `info`, `debug`, or per-module like
# `info,vtop_adapters=debug`. `debug` is very chatty under load.
RUST_LOG=info

# [OPTIONAL] default: pretty. `json` emits structured logs so Alloy -> Loki
# ships parseable fields (level, records, *_ms, byte counts). The log-derived
# Grafana panels REQUIRE json; `pretty` is nicer in a terminal but blanks them.
VTOP_LOG_FORMAT=json

# [OPTIONAL] default: unset — and unset means the metrics server does not run
# at all. Metrics are strictly opt-in. Serves /metrics, /healthz and /readyz.
# Alloy scrapes vtop-engine:9090/metrics. Bind to 127.0.0.1 outside a container
# network; an invalid value is logged and ignored rather than killing the
# engine, because telemetry must never break the data path.
VTOP_METRICS_ADDR=0.0.0.0:9090


# -----------------------------------------------------------------------------
# 4. Kafka SASL (not used by the lab — the lab broker is unauthenticated)
# -----------------------------------------------------------------------------
# VTOP never stores a password in config.yaml. Instead config.yaml names the
# environment variable holding it:
#
#   sources:
#     kafka:
#       sasl_username: vtop
#       sasl_password_env: VTOP_KAFKA_PASSWORD   <-- the NAME, not the secret
#
# The variable named there must exist and be non-empty at startup, or the
# engine fails with a config error rather than silently connecting anonymously.
# The name is yours to choose; VTOP_KAFKA_PASSWORD is only a convention.
#
# VTOP_KAFKA_PASSWORD=


# -----------------------------------------------------------------------------
# 5. Load generator  (profile: load)
# -----------------------------------------------------------------------------
#   docker compose --profile load up -d kafka-load
#
# Produces continuously across every supported format, so the engine sees a
# realistic mixed workload instead of one uniform stream.

# [OPTIONAL] default: kafka:9092. Broker as seen from inside the compose network.
BOOTSTRAP=kafka:9092

# [OPTIONAL] Formats to generate, space-separated. Each gets its own topics, so
# the engine's format detection is exercised across all of them.
FORMATS=cef leef json jsonl syslog logfmt apache text

# [OPTIONAL] default: 3. Topics per format. Total topics = formats x this
# (8 x 3 = 24 here). This number matters for throughput: sources are polled
# SERIALLY, so more topics means a longer cycle (see section 7).
TOPICS_PER_FORMAT=3

# [OPTIONAL] Messages per produce round, picked randomly in this range.
MIN_BATCH=50
MAX_BATCH=500

# [OPTIONAL] default: 1. Pause between rounds — the main throttle. At the
# defaults the GENERATOR, not the engine, is the bottleneck (~150 msg/s
# produced while the engine sustains thousands). Lower it to push harder.
SLEEP_SECONDS=1

# [OPTIONAL] default: 0 = produce forever. Seconds to run, then exit.
DURATION_SECONDS=0


# -----------------------------------------------------------------------------
# 6. Testing / CI
# -----------------------------------------------------------------------------

# [OPTIONAL] default: unset. The Postgres state-store battery SKIPS itself when
# unset, so `cargo test` stays green with no database. Requires a build with
# the feature:  cargo test -p vtop-state --features postgres
# VTOP_TEST_POSTGRES=postgres://vtop:vtop@localhost:5432/vtop

# [OPTIONAL] default: vtop. UID of the Grafana folder the dashboards are seeded
# into. Change only if `vtop` collides with an existing folder.
# GRAFANA_FOLDER_UID=vtop

# [OPTIONAL] default: false. Seeding is non-destructive — an existing dashboard
# is kept, so `docker compose up -d` never reverts your UI edits. Set true to
# deliberately reset the lab to the repo's dashboards:
#   docker compose -f docker-compose.yml -f docker-compose.observability.yml \
#       run --rm -e FORCE_RESEED=true grafana-seed
# FORCE_RESEED=false


# -----------------------------------------------------------------------------
# 7. Not env vars — the YAML knobs that most affect measured throughput
# -----------------------------------------------------------------------------
# Recorded here because a benchmark that ignores them is not reproducible.
# These live in examples/config.yaml under `batching`.
#
#   source_poll_wait_ms      (default 250)
#     How long ONE source read may block waiting for data — paid PER SOURCE,
#     SERIALLY. An EMPTY source burns the whole window before returning
#     nothing, so a cycle over N idle Kafka topics costs up to N x this. It was
#     a hard-coded 2000, which put the lab's 29 topics at ~58s per cycle.
#     Measured, same binary, fixed ~122k-record backlog across 29 partitions:
#         2000ms -> 121,890 records in 688s = 177 rec/s
#          250ms -> 122,160 records in 359s = 340 rec/s   (1.92x)
#
#   idle_poll_interval_ms    (default 2000)
#     Pause between cycles ONLY when the previous cycle read nothing. A cycle
#     that read data loops straight into the next one, so a backlog drains at
#     read speed rather than being throttled by a timer.
#
#   max_records / max_bytes / max_batch_age_seconds  (10000 / 100MiB / 60s)
#     Seal thresholds. A batch seals on whichever trips first. If partitions
#     never reach max_records, everything seals on the age timer and that
#     timer — not I/O — sets your throughput ceiling.


# -----------------------------------------------------------------------------
# 8. Where the lab listens
# -----------------------------------------------------------------------------
#   Grafana    http://127.0.0.1:3400   admin / admin
#              Loopback ONLY, deliberately: anonymous access is granted Editor,
#              so anyone who could reach the port could delete any dashboard
#              without signing in. [LAB ONLY]
#   MinIO      http://localhost:9001   minioadmin / minioadmin  [LAB ONLY]
#   Alloy      http://localhost:12345  (which scrape targets are actually UP)
#   Engine     http://localhost:9090/metrics  (only if VTOP_METRICS_ADDR is set)
